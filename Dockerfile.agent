FROM golang:1.22-alpine AS builder
WORKDIR /src
COPY . .
RUN go build -trimpath -ldflags="-s -w" -o /out/relayguard-agent ./cmd/relayguard-agent

FROM alpine:3.20
RUN apk add --no-cache ca-certificates tzdata
COPY --from=builder /out/relayguard-agent /usr/local/bin/relayguard-agent
ENTRYPOINT ["/usr/local/bin/relayguard-agent"]
