FROM golang:1.22-alpine AS builder
WORKDIR /src
COPY go.mod ./
COPY internal/ internal/
COPY cmd/ cmd/
RUN go mod tidy 2>/dev/null || true
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/relayguard-agent ./cmd/relayguard-agent

FROM alpine:3.20
RUN apk add --no-cache ca-certificates tzdata iptables iproute2
COPY --from=builder /out/relayguard-agent /usr/local/bin/relayguard-agent
# Agent needs host network and NET_ADMIN for iptables
ENTRYPOINT ["/usr/local/bin/relayguard-agent"]